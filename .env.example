# 示例环境变量（复制为项目根目录 .env 自行填写；.env 已忽略，勿提交）
# 本机开发可不建此文件：默认调试开、用代码内临时占位钥匙即可

# 云上正式运行必填（生成示例：在项目目录执行）
#   .venv/bin/python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 云上正式：设为 0 关闭调试页
YECAO_DEBUG=0

# 云上允许访问的域名与 IP，逗号分隔，例如：
# YECAO_ALLOWED_HOSTS=yichbo.com,www.yichbo.com,8.138.255.177
YECAO_ALLOWED_HOSTS=

# 体验机模式（公网体验服务器开；本机开发一般不开）
YECAO_EXPERIENCE_SITE=0
# YECAO_EXPERIENCE_NOTIFY_EMAIL=you@example.com

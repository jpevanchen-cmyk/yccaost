# 示例环境变量（复制为项目根目录 .env 自行填写；.env 已忽略，勿提交）
# 本机开发可不建此文件：默认调试开、用代码内临时占位钥匙即可

# 云上正式运行必填（生成示例：在项目目录执行）
#   .venv/bin/python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 云上正式：设为 0 关闭调试页
YECAO_DEBUG=0

# 云上允许访问的域名与 IP，逗号分隔，例如：
# YECAO_ALLOWED_HOSTS=yichbo.com,www.yichbo.com,8.138.255.177
YECAO_ALLOWED_HOSTS=

# 体验机模式（仅开发者私人体验部署需要时开启；正式服务器默认关闭）
# 详见 docs/正式服务器与体验机分界.md 、 docs/体验机与官方小店约定.md
YECAO_EXPERIENCE_SITE=0
# YECAO_EXPERIENCE_NOTIFY_EMAIL=you@example.com

# 发信邮箱（新订单邮件通知等要用；不填则不发邮件，也不报错）
# 常见示例：QQ邮箱 smtp.qq.com:465(SSL)；163邮箱 smtp.163.com:465(SSL)；
# 密码多为「授权码」而非登录密码，请到邮箱设置里开启 SMTP 并获取授权码。
# YECAO_EMAIL_HOST=smtp.qq.com
# YECAO_EMAIL_PORT=465
# YECAO_EMAIL_USER=you@qq.com
# YECAO_EMAIL_PASSWORD=你的SMTP授权码
# YECAO_EMAIL_SSL=1
# YECAO_EMAIL_TLS=0
# YECAO_EMAIL_FROM=you@qq.com

# 服务器拥有者私人工具包（默认关闭；owner_toolkit/ 目录不进公开 Git）
# YECAO_OWNER_TOOLKIT_ENABLED=1
# YECAO_OWNER_TOOLKIT_PATH=owner_toolkit

# 邮件防刷（可选调整）
# YECAO_EMAIL_DAILY_SERVER_MAX=400
# YECAO_EMAIL_RECIPIENT_HOURLY_MAX=5
# YECAO_EMAIL_RECIPIENT_DAILY_MAX=20
# YECAO_EMAIL_DEDUPE_COOLDOWN_SECONDS=600
# YECAO_GUESTBOOK_ACTOR_HOURLY_MAX=3
# YECAO_GUESTBOOK_ACTOR_DAILY_MAX=15
